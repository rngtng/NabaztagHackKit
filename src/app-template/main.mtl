/**
 * Template app — assembly only.
 * Everything below the "business logic" line comes from lib/ building blocks;
 * app.mtl is the only file you need to touch for your own app.
 *
 * Transports (include exactly one):
 *  - simulator (task simulate:app, SIMU defined): lib/net/tcp.mtl bridges the
 *    sim's TCP natives — no network stack needed
 *  - device (task build:app): lib/net/net.mtl brings the full MTL stack
 *    (wifi/ARP/IP/TCP/DHCP/DNS), configured via the config_get_* accessors
 *    defined in app.mtl
 */
proto main 0;;

// Building blocks
#ifdef SIMU
#include "lib/net/tcp.mtl"
#else
#include "lib/net/net.mtl"
#endif
#include "lib/net/http_server.mtl"
#include "lib/forth.mtl"
#include "lib/sys/task.mtl"
#include "lib/sys/time.mtl"
#include "lib/forth/time.mtl"   // opt-in Forth time/date word pack
#include "lib/forth/task.mtl"   // opt-in Forth task-control word pack

// Forth: dictionary + word packs are wired up in app.mtl (extend there)

// Business logic
#include "app.mtl"

fun main=
    loopcb #task_scheduler;
#ifdef SIMU
    netstart;
#else
    net_init;
    wifi_init 0;
#endif
    starthttpsrv 80 #handle_request;
    0;;
