#endif
#ifdef TELNETSERVER
#include "srv/telnet_server.mtl"
#endif

#include "run/run.mtl"
#include "forth/forth.mtl"

fun main=
    // Set the loop callback
    loopcb #task_scheduler;
    // Initialize the ears; hook interactive mode + run-state reset waiters
    // into the lib state machine
    ears_init;
    set ears_touched_cb = #_ears_touched_interactive;
    set chor_started_cb = #_chor_started;
    set chor_stopped_cb = #_chor_stopped;
    set ears_post_run_cb = #_ears_reset_check;
    // Load the configuration
    config_load;
    // Init the wifi and start the wifi job
    wifi_init 0;
    // Initialize the network stack, start the network jobs
    net_init;
    // Initialize and start the info task
    info_init;
    // Start the time update job
    time_init;
    // Start the NTP client
    ntp_init;
    audiolib_init;
    button_init;
    record_init;
    // Initialize the leds
    leds_init;
    // Initialize interactive mode (set defaults and start the interactive ears task)
    interactive_init;
    // Start the main loop
    run_init;
    // Start the servers
#ifdef WEBSERVER
    http_server_start_srv PORT_HTTP;
#endif
#ifdef XMPP
    xmpp_init;
#endif
    0;;
