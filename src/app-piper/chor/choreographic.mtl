/**
 * App hooks into the lib choreography engine (lib/chor/choreographic.mtl):
 * the run-state machine schedules chor_run_cmd while a chor plays.
 * Wired in main via the chor_*_cb seams.
 */
#include "protos/chor_protos.mtl"
#include "protos/run_protos.mtl"
#include "lib/chor/choreographic.mtl"

fun _chor_started cb_args=
    run_set_state chorCmdRun cb_args;;

fun _chor_stopped=
    run_set_state idleRun;;
