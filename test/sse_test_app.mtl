proto main 0;;

// Minimal TCP emulation (subset of src/boot/tcpudp_emu.mtl, no UDP/DHCP needed)
var TCPWRITE=0;;
var TCPREAD=1;;
var TCPCLOSE=-1;;
var TCPSTART=2;;

var ltcp;;
var netip="\127\0\0\1";;

fun writetcp t msg i=
    tcpSend t msg i nil;;

fun _remtcp l t=
    if l!=nil then let hd l->[tt _] in if t==tt then tl l
    else (hd l)::_remtcp tl l t;;

fun _updatetcp l t cb=
    if l!=nil then let hd l->[tt _] in if t==tt then [t cb]::tl l
    else (hd l)::_updatetcp tl l t cb;;

fun closetcp t=
    set ltcp=_remtcp ltcp t;
    tcpClose t;;

fun tcpcb t cb=
    set ltcp=_updatetcp ltcp t cb;
    cb;;

fun listentcp port cb=
    set ltcp=[tcpListen port cb]::ltcp;;

fun nettcp t val msg=
    if val==TCPSTART then
        let listswitch ltcp atoi msg -> cb in
        (
            set ltcp=[t cb]::ltcp;
            call cb [t val msg]
        )
    else let listswitch ltcp t -> cb in
        call cb [t val msg];;

fun netstart=
    tcpCb #nettcp;
    set ltcp=nil;
    0;;

#include "lib/sse_server.mtl"

var _tick = 0;;
var _last_broadcast = nil;;

fun sse_on_accept cnx val msg=
    if val==TCPSTART then sse_accept_client cnx;;

fun sse_loop=
    let time_ms -> now in
    if _last_broadcast==nil || now - _last_broadcast >= 2000 then
    (
        set _last_broadcast = now;
        set _tick = _tick + 1;
        sse_broadcast "test" strcatlist "\"tick\": " :: (itoa _tick) :: nil
    );;

fun main=
    netstart;
    listentcp 80 #sse_on_accept;
    loopcb #sse_loop;;
