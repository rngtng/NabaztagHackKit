let scenario "forth_memory_test" -> s in
(
  let test "variable store fetch" -> t in
  (
    assert_equalS "0"  forth_run_stack "variable v0  0 v0 !  v0 @";
    assert_equalS "42" forth_run_stack "variable v1  42 v1 !  v1 @"
  );

  let test "+! adds in place" -> t in
  (
    assert_equalS "43" forth_run_stack "variable v2  42 v2 !  1 v2 +!  v2 @";
    assert_equalS "40" forth_run_stack "variable v3  30 v3 !  10 v3 +!  v3 @"
  );

  let test "? prints the cell" -> t in
  (
    assert_equalS "5 " forth_run "variable v4  5 v4 !  v4 ?"
  );

  let test "allocate-cell store fetch" -> t in
  (
    assert_equalS "99" forth_run_stack "allocate-cell dup 99 swap ! @";
    assert_equalS ""   forth_run_stack "allocate-cell free-cell"
  );

  let test "state cell reads interpreter state" -> t in
  (
    assert_equalS "0" forth_run_stack "state @"
  )
);
