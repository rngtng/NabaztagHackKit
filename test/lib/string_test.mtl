let scenario "string_test" -> s in
(
  let test "strstr" -> t in
  (
    assert_equalI 0   strstr "hello" "hel" 0;
    assert_equalI 2   strstr "hello" "llo" 0;
    assert_equalI nil strstr "hello" "xyz" 0;
    assert_equalI nil strstr "" "a" 0
  );

  let test "countpattern" -> t in
  (
    assert_equalI 0 countpattern "hello" "xyz" 0;
    assert_equalI 1 countpattern "hello" "ell" 0;
    assert_equalI 2 countpattern "aXbXc" "X" 0;
    assert_equalI 4 countpattern "aaaa" "a" 0
  );

  let test "strreplace" -> t in
  (
    assert_equalS "hello" strreplace "hello" "xyz" "Z";
    assert_equalS "hZllo" strreplace "hello" "e" "Z";
    assert_equalS "helo"  strreplace "hello" "ll" "l";
    assert_equalS "AB-AB" strreplace "X-X" "X" "AB"
  );

  let test "to_lower" -> t in
  (
    assert_equalS "hello"       to_lower "HELLO";
    assert_equalS "hello"       to_lower "hello";
    assert_equalS "hello world" to_lower "Hello World"
  );

  let test "to_upper" -> t in
  (
    assert_equalS "HELLO"       to_upper "hello";
    assert_equalS "HELLO"       to_upper "HELLO";
    assert_equalS "HELLO WORLD" to_upper "Hello World"
  );

  let test "str_repeat" -> t in
  (
    assert_equalS ""     str_repeat "a"  0;
    assert_equalS "aaa"  str_repeat "a"  3;
    assert_equalS "abab" str_repeat "ab" 2
  );

  let test "zero_pad" -> t in
  (
    assert_equalS "001" zero_pad "1"   3;
    assert_equalS "123" zero_pad "123" 3;
    assert_equalS "123" zero_pad "123" 2
  );

  let test "str_pad_right" -> t in
  (
    assert_equalS "000hi" str_pad_right "hi" 5 "0";
    assert_equalS "hi"    str_pad_right "hi" 2 "0";
    assert_equalS "hi"    str_pad_right "hi" 1 "0"
  );

  let test "str_pad_left" -> t in
  (
    assert_equalS "hi000" str_pad_left "hi" 5 "0";
    assert_equalS "hi"    str_pad_left "hi" 2 "0";
    assert_equalS "hi"    str_pad_left "hi" 1 "0"
  );

  let test "count_char" -> t in
  (
    assert_equalI 0 count_char "hello" 'x';
    assert_equalI 1 count_char "hello" 'e';
    assert_equalI 2 count_char "hello" 'l'
  );

  let test "str_compare" -> t in
  (
    assert_equalI  0 str_compare "abc" "abc";
    assert_equalI -1 str_compare "abc" "abd";
    assert_equalI  1 str_compare "abd" "abc";
    assert_equalI -1 str_compare "ab"  "abc";
    assert_equalI  1 str_compare "abc" "ab"
  );

  let test "is_numeric" -> t in
  (
    assert_equalI 1 is_numeric "123";
    assert_equalI 1 is_numeric "-42";
    assert_equalI 0 is_numeric "12a";
    assert_equalI 0 is_numeric "abc"
  )
);
