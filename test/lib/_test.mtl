// Forth: core dictionary + the opt-in time pack (its deps — lib/sys/time.mtl,
// ntp, config_get_* — are all included/stubbed above); run a program, return
// buffered output / stack
#include "lib/forth.mtl"
#include "lib/forth/time.mtl"

fun _forth_test_time_words=
    [ [str: "time&date"    ] [func:#forth_time_and_date]] ::
    [ [str: "local>string" ] [func:#forth_local_to_string]] ::
    [ [str: "utc>string"   ] [func:#forth_utc_to_string]] ::
    [ [str: "time-ms"      ] [func:#forth_time_ms]] ::
    [ [str: "uptime"       ] [func:#forth_uptime]] ::
    [ [str: "ms"           ] [func:#forth_ms flag:FORTH_ASYNC]] ::
    [ [str: "update-time"  ] [func:#forth_update_time]] ::
    [ [str: "time?"        ] [func:#forth_time_q]] ::
    nil;;

fun forth_init_dictionary=
    set forth_dictionary = [dict: conc _forth_test_time_words forth_core_words];
    0;;

// The dictionary is built once (lazily by forth_interpreter_setup);
// rebuilding it per run exhausts the simulator heap.
fun forth_run src=
  let forth_interpreter_setup src nil nil nil nil -> f in
  (
    forth_interpreter_loop f;
    strcatlist rev f.output nil
  );;

fun forth_run_stack src=
  let forth_interpreter_setup src nil nil nil nil -> f in
  (
    forth_interpreter_loop f;
    forth_list_to_str f.stack " "
  );;

var test_http_req;;
fun test_http_handler req=
  set test_http_req=req;
  "<html>ok</html>";;

fun cmpI a b= if a<b then -1 else 1;;
fun gtI x a= x>a;;

