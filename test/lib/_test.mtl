// Capturing stubs for the VM TCP primitives required by lib/net modules.
// writetcp appends to test_tcp_out; test_tcp_partial simulates short writes.
const TCPWRITE=0;;
const TCPCLOSE=-1;;
var test_tcp_out="";;
var test_tcp_closed=0;;
var test_tcp_partial;;

fun test_tcp_reset=
  set test_tcp_out="";
  set test_tcp_closed=0;
  set test_tcp_partial=nil;
  0;;

fun writetcp t msg i=
  let if i==nil then 0 else i -> start in
  let (strlen msg)-start -> remaining in
  let if test_tcp_partial!=nil && test_tcp_partial<remaining then test_tcp_partial else remaining -> n in
  (
    set test_tcp_out=strcat test_tcp_out strsub msg start n;
    start+n
  );;

fun closetcp t= set test_tcp_closed=1; 0;;
fun tcpcb t cb= 0;;
fun listentcp port cb= 0;;

#include "lib/net/sock.mtl"
#include "lib/net/http_server.mtl"
#include "lib/net/sse_server.mtl"

// Forth: core dictionary only; run a program, return buffered output / stack
#include "lib/forth.mtl"

fun forth_init_dictionary= forth_init_core_dictionary;;

// The dictionary is built once (lazily by forth_interpreter_setup);
// rebuilding it per run exhausts the simulator heap.
fun forth_run src=
  let forth_interpreter_setup src nil nil nil nil -> f in
  (
    forth_interpreter_loop f;
    strcatlist rev f.output nil
  );;

fun forth_run_stack src=
  let forth_interpreter_setup src nil nil nil nil -> f in
  (
    forth_interpreter_loop f;
    forth_list_to_str f.stack " "
  );;

var test_http_req;;
fun test_http_handler req=
  set test_http_req=req;
  "<html>ok</html>";;

fun cmpI a b= if a<b then -1 else 1;;
fun gtI x a= x>a;;

