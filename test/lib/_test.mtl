fun tcp_set_cb t cb= 0;;
fun tcp_set_enabled t v= 0;;
fun tcp_is_enabled t= 1;;
fun tcp_listen port cb= 0;;
fun tcp_handler src mac= 0;;
fun tcp_init= 0;;
fun tcp_reset= 0;;

