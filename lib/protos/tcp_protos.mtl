// TCP callback event values (val argument of connection callbacks)
const TCPWRITE=0;;
const TCPREAD=1;;
const TCPCLOSE=-1;;
const TCPSTART=2;;

proto tcp_close 1;;
proto tcp_handler 2;;
proto tcp_init 0;;
proto tcp_is_enabled 1;;
proto tcp_listen 2;;
proto tcp_open 5;;
proto tcp_reset 0;;
proto tcp_set_enabled 2;;
proto tcp_write 3;;
