// The Wifi type, `wifi`/`_wifi_master`/`_wifi_scans` state and the RT2501/
// IEEE80211 constants are all owned by the wifi module (wifi.mtl, included
// below): lib/net/wifi.mtl on device, boot's own state machine on SIMU. It is
// included *before* config_server.mtl so those symbols (and the shared mutable
// _wifi_* vars) resolve to a single declaration ahead of their first use.

// On the device build these live in lib/protos/net_protos.mtl (pulled in by
// ipv4.mtl). The simulator's tcpudp_emu.mtl doesn't include that header, so
// declare them here for the SIMU build only.
#ifdef SIMU
var netip="\0\0\0\0";;
var netmask="\255\255\255\0";;
var netgateway="\0\0\0\0";;
var mymac;;
const macbroadcast="\$ff\$ff\$ff\$ff\$ff\$ff";;
const ipbroadcast="\$ff\$ff\$ff\$ff";;
const netip_empty="\0\0\0\0";;
const netip_master="\192\168\0\1";;
const netmask_master="\255\255\255\0";;
const netgateway_master="\192\168\0\1";;
#endif

// The simulator resolver keeps a single DNS server here; on device the DNS
// server list lives in lib/net's netdnslist (boot_dns_* in dns.mtl bridges).
var netdns="\0\0\0\0";;

const FIRMWARE="\0\0\0\13";;


